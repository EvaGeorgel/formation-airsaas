<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AirSaaS — Formation Professionnelle</title>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #0D0F14; --muted: #6B7280; --border: #E5E7EB; --surface: #FFFFFF; --bg: #F8F9FB;
  --blue: #3B5BDB; --violet: #7C3AED; --emerald: #059669; --amber: #D97706; --rose: #E11D48;
  --r: 16px; --r-sm: 10px; --sh-lg: 0 12px 40px rgba(0,0,0,.12);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Instrument Sans', sans-serif; background: var(--bg); color: var(--ink); font-size: 15px; line-height: 1.6; }
h1,h2,h3,h4 { font-family: 'Bricolage Grotesque', sans-serif; line-height: 1.2; }

/* TOP NAVIGATION CORRIGÉE */
#topbar {
  position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20px); border-bottom: 1px solid var(--border);
  display: flex; align-items: center; height: 60px; padding: 0 24px;
}
.tb-logo { display: flex; align-items: center; gap: 10px; margin-right: 32px; flex-shrink: 0; font-weight: 700; }
.tb-logo span { color: var(--blue); }
.tb-modules { display: flex; align-items: center; gap: 2px; flex: 1; overflow-x: auto; scrollbar-width: none; }
.tb-modules::-webkit-scrollbar { display: none; }
.tb-mod { display: flex; align-items: center; gap: 7px; padding: 6px 14px; border-radius: 8px; cursor: pointer; white-space: nowrap; font-size: 13px; font-weight: 500; color: var(--muted); transition: all 0.18s; }
.tb-mod.active { color: var(--blue); background: #EEF2FF; font-weight: 600; }
.tb-mod.done { color: var(--emerald); }

/* PROGRESS BAR */
.tb-right { display: flex; align-items: center; gap: 12px; margin-left: 16px; flex-shrink: 0; }
.tb-prog-bar { width: 80px; height: 4px; background: var(--border); border-radius: 99px; overflow: hidden; }
.tb-prog-fill { height: 100%; background: linear-gradient(90deg, var(--blue), var(--violet)); transition: width 0.5s; }

/* LAYOUT */
.page { display: none; }
.page.active { display: block; animation: pageIn 0.3s ease; }
@keyframes pageIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
.hero { padding: 64px 64px 48px; max-width: 1100px; margin: 0 auto; text-align: center; }
.content-wrap { max-width: 1100px; margin: 0 auto; padding: 0 64px 80px; }

/* CARDS & ELEMENTS */
.card { background: var(--surface); border-radius: var(--r); border: 1px solid var(--border); padding: 32px; margin-bottom: 20px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
.card-head { font-size: 17px; font-weight: 700; margin-bottom: 14px; display: flex; align-items: center; gap: 10px; }
.ch-icon { width: 34px; height: 34px; border-radius: 9px; display: flex; align-items: center; justify-content: center; }
.section-title { font-size: 11px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: var(--muted); margin: 40px 0 16px; display: flex; align-items: center; gap: 10px; }
.section-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

.callout { border-radius: var(--r-sm); padding: 16px 20px; margin: 14px 0; display: flex; gap: 12px; font-size: 14px; }
.co-blue { background: #EEF2FF; border: 1px solid rgba(59,91,219,0.15); }
.st-pill { padding: 4px 12px; border-radius: 99px; font-size: 12px; font-weight: 600; display: inline-block; margin: 2px; }
.st-cadrage { background: #FFFBEB; color: #92400E; border: 1px solid #FCD34D; }
.st-exec { background: #ECFDF5; color: #065F46; border: 1px solid #6EE7B7; }

.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.risk-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.risk-card { background: white; border: 1px solid var(--border); padding: 20px; border-radius: var(--r); text-align: center; font-weight: 600; }

.ss-wrap { margin: 24px 0; border-radius: var(--r); overflow: hidden; box-shadow: var(--sh-lg); border: 1px solid var(--border); }
.ss-wrap img { width: 100%; display: block; }

.btn { padding: 12px 22px; border-radius: 10px; font-weight: 600; cursor: pointer; border: none; transition: 0.2s; }
.btn-primary { background: var(--blue); color: white; }

@media (max-width: 820px) { .grid-2, .risk-grid { grid-template-columns: 1fr; } .hero, .content-wrap { padding: 20px; } }
</style>
</head>
<body>

